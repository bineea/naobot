#!/bin/sh

if command -v python >/dev/null 2>&1; then
  exec python tools/check_prd_sync.py
fi

if command -v python3 >/dev/null 2>&1; then
  exec python3 tools/check_prd_sync.py
fi

if command -v py >/dev/null 2>&1; then
  exec py -3 tools/check_prd_sync.py
fi

echo "未找到 Python，无法执行 PRD 一致性检查。" >&2
exit 1
